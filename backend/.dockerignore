# Dependencies (installed in Dockerfile from requirements.txt)
node_modules
**/node_modules
.pnp
**/.pnp.js

# Netlify CLI/plugins — not used on Fly (~130MB+)
.netlify
**/.netlify

# Python caches
__pycache__
**/__pycache__
*.py[cod]
*$py.class
.pytest_cache
.mypy_cache
.ruff_cache
venv
.venv
env

# Git / IDE / OS
.git
.gitignore
**/.DS_Store
**/.vscode/*
!**/.vscode/extensions.json
**/.idea
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?

# Env files (use fly secrets)
.env
.env.*
!.env.example

# Build artifacts & coverage
coverage
build
dist
htmlcov

# Logs & local media (not needed in production image)
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
*.log
**/*.mp4

# Docs / dev-only (optional slimming)
*.md
!README.md
